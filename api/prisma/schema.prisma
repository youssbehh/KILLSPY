// KILLSPY Prisma schema
// Cleaned Phase 6 — dropped legacy shop tables, added cosmetic system.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// =====================================================================
// CORE
// =====================================================================

model Users {
  ID_User      Int       @id @default(autoincrement())
  Username     String    @unique
  Email        String    @unique
  Password     String
  MMR          Int       @default(0)
  Money        Int       @default(100)
  isGuest      Boolean   @default(false)
  CreatedAt    DateTime  @default(now())
  archived     Boolean   @default(false)
  deletionDate DateTime?

  Roles     Roles[]
  Sessions  Session[]
  Friends   Friends[]     @relation("user_friendships")
  FriendOf  Friends[]     @relation("friend_of")
  Result    GameHistory[]
  Cosmetics UserCosmetic[]
  Equipped  EquippedCosmetic[]
}

model Session {
  ID_Session      Int      @id @default(autoincrement())
  Connected       Boolean
  LastConnection  DateTime
  TotalLoginCount Int
  User            Users    @relation(fields: [ID_User], references: [ID_User], onDelete: Cascade)
  ID_User         Int
}

model Roles {
  ID_Role Int    @id @default(autoincrement())
  Role    String
  User    Users  @relation(fields: [ID_User], references: [ID_User], onDelete: Cascade)
  ID_User Int
}

model Friends {
  ID_Friendship Int      @id @default(autoincrement())
  Connected     Boolean  @default(false)
  Blocked       Boolean  @default(false)
  CreatedAt     DateTime @default(now())

  User      Users @relation("user_friendships", fields: [ID_User], references: [ID_User], onDelete: Cascade)
  ID_User   Int
  Friend    Users @relation("friend_of",        fields: [ID_Friend], references: [ID_User], onDelete: Cascade)
  ID_Friend Int

  @@unique([ID_User, ID_Friend])
}

// =====================================================================
// GAMES
// =====================================================================

enum GameModePersisted {
  pvp_quick
  pvp_ranked
}

model GameHistory {
  ID_GameHistory Int               @id @default(autoincrement())
  V_D            Boolean
  DateGame       DateTime          @default(now())
  MMRWin         Int               @default(0)
  Mode           GameModePersisted @default(pvp_quick)
  User           Users             @relation(fields: [ID_User], references: [ID_User], onDelete: Cascade)
  ID_User        Int

  @@index([ID_User, Mode, DateGame])
}

// =====================================================================
// COSMETICS / SHOP
// =====================================================================

enum CosmeticType {
  avatar         // photo de profil
  card_skin      // habillage des cartes / interface jeu
  emote          // réaction in-game
  background     // fond achetable (différent du thème UI)
  ui_theme       // thème de couleurs de l'UI (5 variantes proposées + défaut offert)
  shoot_anim     // animation de tir (futur)
  shield_anim    // animation de bouclier (futur)
  name_effect    // effet visuel sur le pseudo (futur)
}

enum Rarity {
  common      // gris
  uncommon    // vert
  rare        // bleu
  epic        // violet
  legendary   // or
  mythic      // rouge
  secret      // noir étoilé
}

model CosmeticItem {
  id        Int          @id @default(autoincrement())
  type      CosmeticType
  name      String       @unique
  imageUrl  String
  basePrice Int
  rarity    Rarity       @default(common)
  available Boolean      @default(true)
  createdAt DateTime     @default(now())

  owned     UserCosmetic[]
  equipped  EquippedCosmetic[]
  offers    ShopOffer[]

  @@index([type, available])
  @@index([rarity])
}

model UserCosmetic {
  id         Int          @id @default(autoincrement())
  user       Users        @relation(fields: [userId], references: [ID_User], onDelete: Cascade)
  userId     Int
  item       CosmeticItem @relation(fields: [itemId], references: [id], onDelete: Cascade)
  itemId     Int
  pricePaid  Int
  acquiredAt DateTime     @default(now())

  @@unique([userId, itemId])
  @@index([userId])
}

model EquippedCosmetic {
  id     Int          @id @default(autoincrement())
  user   Users        @relation(fields: [userId], references: [ID_User], onDelete: Cascade)
  userId Int
  type   CosmeticType
  item   CosmeticItem @relation(fields: [itemId], references: [id], onDelete: Cascade)
  itemId Int

  @@unique([userId, type])
  @@index([userId])
}

model ShopOffer {
  id         Int          @id @default(autoincrement())
  item       CosmeticItem @relation(fields: [itemId], references: [id], onDelete: Cascade)
  itemId     Int
  price      Int
  validUntil DateTime
  position   Int          @default(0)
  active     Boolean      @default(true)

  @@index([active, validUntil])
}
